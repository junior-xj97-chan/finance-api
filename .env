# MySQL 配置（开发环境）
DB_HOST=localhost
DB_PORT=3306
DB_NAME=finance_api
DB_USER=root
DB_PWD=root123

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PWD=

# RabbitMQ 配置
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PWD=guest

# JWT 密钥（生产环境务必修改！至少 256 bits）
JWT_SECRET=finance-api-secret-key-change-in-production-min-256bits

# 服务端口
SERVER_PORT=8080

# 日志级别
LOG_LEVEL=info
